# MongoDB Connection URI
MONGO_URI=your_database_uri_here

# NextAuth Secret Configuration (Generate using: openssl rand -base64 32)
NEXTAUTH_SECRET=your_nextauth_secret_here

# NextAuth OAuth Providers
# Google Developer Console OAuth Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Microsoft Azure Active Directory (Azure AD) Credentials
AZURE_AD_CLIENT_ID=your_azure_ad_client_id_here
AZURE_AD_CLIENT_SECRET=your_azure_ad_client_secret_here
AZURE_AD_TENANT_ID=your_azure_ad_tenant_id_here

# Third-Party External APIs
# API Ninjas API Key (For daily inspirational quotes)
NEXT_PUBLIC_QUOTES=your_api_ninjas_key_here

# OpenWeatherMap API Key (For current weather widget display)
NEXT_PUBLIC_WEATHER=your_openweathermap_api_key_here
